# Server
PORT=5000
NODE_ENV=development

# Client (for CORS)
CLIENT_URL=http://localhost:5173

# MongoDB
# NOTE: Transactions require a replica set. Use MongoDB Atlas or a local
# replica set (mongod --replSet rs0). A standalone mongod will NOT support
# the reservation transaction logic.
MONGO_URI=mongodb://127.0.0.1:27017/ticket-booking?replicaSet=rs0

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Comma-separated emails that become 'admin' automatically when they register.
# Admins are the only users who can create events from the UI / POST /api/events.
ADMIN_EMAILS=admin@example.com

# Reservation hold time in minutes
RESERVATION_TTL_MINUTES=10
